                    for (i = 0; i < regions.length; i++) {
                        if (regions[i][0] == input) {
                            return regions[i][1];
                        }
                    }
                } else if (to == "name") {
                    input = input.toUpperCase();
                    for (i = 0; i < regions.length; i++) {
                        if (regions[i][1] == input) {
                            return regions[i][0];
                        }
                    }
                }
            }
            
