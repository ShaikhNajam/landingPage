        <script type="text/javascript">
            var allArr = [];
            var whitespace = " \t\n\r";

            function isValidEmail(s) {
                if (isEmpty(s)) return false;
                if (isWhitespace(s)) return false;
                var i = 1;
                var sLength = s.length;
                while (i < sLength && s.charAt(i) != "@") {
                    i++;
                }
                if (i >= sLength || s.charAt(i) != "@") return false;
                else i += 2;
                while (i < sLength && s.charAt(i) != ".") {
                    i++;
                }
                if (i >= sLength - 1 || s.charAt(i) != ".") return false;
                else return true;
            }

            function isEmpty(s) {
                return s == null || s.length == 0;
            }

            function isWhitespace(s) {
                var i;
                if (isEmpty(s)) return true;
                for (i = 0; i < s.length; i++) {
                    var c = s.charAt(i);
                    if (whitespace.indexOf(c) == -1) return false;
                }
                return true;
            }

            function getParam(name) {
                name = name.replace(/[\[]/, "\\[").replace(/[\]]/, "\\]");
                var regex = new RegExp("[\\?&]" + name + "=([^&#]*)");
                var results = regex.exec(location.search);
                return results === null ? "" : decodeURIComponent(results[1].replace(/\+/g, " "));
            }

            function phoneMask(e) {
                var num = e.target.value.replace(/\D/g, "");
                e.target.value = "(" + num.substring(0, 3) + ") " + num.substring(3, 6) + "-" + num.substring(6, 10);
            }
            document.addEventListener("DOMContentLoaded", function () {
                document.querySelectorAll('[type="tel"]').forEach(function (el) {
                    el.addEventListener("keyup", phoneMask);
                });
            });

            window.onload = function () {
                var suc = document.subscribeForm.elements["_successURL"];
                var ero = document.subscribeForm.elements["_errorURL"];

                suc.value =
                    window.location.href.indexOf("?") == -1
                        ? window.location.href + "?sucMsg=true"
                        : window.location.href + "&sucMsg=true";

                ero.value =
                    window.location.href.indexOf("?") == -1
                        ? window.location.href + "?eroMsg=true"
                        : window.location.href + "&eroMsg=true";

                if (getParam("sucMsg") == "true") {
                    window.location.href = "https://cloud.mc.zoetis.com/portela-coming-soon-ty";
                } else if (getParam("eroMsg") == "true") {
                    alert("Something went wrong! please contact us on 1-888-963-8471");
                    window.location.replace(window.location.href.replace(window.location.search, ""));
                }
            };

            function closeSearchModal() {
                document.getElementById("popup_form_wrapper").style.display = "none";
            }

            function getCall() {
                var v = document.getElementById("zip_code").value;

                if (isEmpty(v)) {
                    alert("Please enter a zip code.");
                    return false;
                } else if (v.length < 5) {
                    alert("Please enter a valid 5-digit zip code.");
                    return false;
                }

                hideManualEntry();
                document.body.style.cursor = "wait";
                var appendSearchDiv = document.getElementById("search_results_container");
                appendSearchDiv.innerHTML = "";

                var xhr = new XMLHttpRequest();
                xhr.onload = function () {
                    if (xhr.status >= 200 && xhr.status < 300) {
                        if (!isEmpty(xhr.response)) {
                            var response = JSON.parse(xhr.response);
                            console.log("getCall: fetched");
                            var ClinicInfo = "";
                            if (Object.keys(response).length > 0 && response.ClinicInfo) {
                                var gerResp = response.ClinicInfo;
                                for (var j = 0; j < gerResp.length; j++) {
                                    allArr[j] = gerResp[j];
                                    var clinic_name = gerResp[j].ClinicName || "";
                                    var street = gerResp[j].BillingStreet || "";
                                    var city = gerResp[j].BillingCity || "";
                                    var narcID = gerResp[j].NarcID || "";
                                    var state = gerResp[j].BillingState || "";
                                    var city_zip_state = city + " " + narcID + " " + state;

                                    ClinicInfo +=
                                        "<div class='radio_input_box'><input class='pp_radio_input' type='radio' name='pp_radio' value='" +
                                        j +
                                        "' required ><label class='pp_radio_label' for='pp_radio_one'><p>" +
                                        clinic_name +
                                        "</p><p>" +
                                        city_zip_state +
                                        "</p></label></div>";
                                }
                            }
                            if (ClinicInfo.length > 0) {
                                ClinicInfo +=
                                    "<div class='pp_fm_btn_wrapper'><button type='button' class='btn btn-primary submit-btn radio_fm_btn' id='radio_fm_btn' onclick='addZipLocation();'>Add Location</button></div>";
                            } else {
                                ClinicInfo =
                                    "<div class=''><label class='pp_radio_label'><p>There is no result found by " +
                                    v +
                                    " zip code</p></label></div>";
                            }
                            appendSearchDiv.innerHTML = ClinicInfo;
                            document.getElementById("popup_form_wrapper").style.display = "block";
                        }
                    } else {
                        console.log(xhr);
                        alert("Error fetching data. Please try again.");
                    }
                    document.body.style.cursor = "default";
                };
                xhr.onerror = function () {
                    document.body.style.cursor = "default";
                    alert("Network error. Please check your connection and try again.");
                };
                xhr.open("GET", "https://cloud.mc.zoetis.com/2023_05_landing_page_with_form_ssjs?zip=" + v);
                xhr.setRequestHeader("Content-Type", "application/json");
                xhr.send();
                return false;
            }

            function addZipLocation() {
                var radioButtons = document.querySelectorAll('input[name="pp_radio"]');
